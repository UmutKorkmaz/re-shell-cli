    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .${normalizedName}-main-content {
    flex: 1;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .${normalizedName}-breadcrumbs {
    margin-bottom: 2rem;
    padding: 1rem;
