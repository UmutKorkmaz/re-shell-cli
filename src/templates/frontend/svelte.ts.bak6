    margin: 0 0.5rem;
    color: #6c757d;
  }

  .breadcrumb-current {
    color: #495057;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .${normalizedName}-main-content {
      padding: 1rem;
    }
  }
</style>`;
